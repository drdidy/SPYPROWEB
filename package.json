{
  "name": "spy-prophet-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "node -e \"console.log('unit test harness pending')\"",
    "test:e2e": "node scripts/run-playwright-smoke.mjs",
    "test:e2e:smoke": "npx playwright test tests/dashboard/smoke.spec.ts --reporter=line --workers=1",
    "test:e2e:visual": "npx playwright test tests/visual --reporter=line --workers=1",
    "test:e2e:all": "npx playwright test tests/dashboard tests/visual --reporter=line --workers=1",
    "test:a11y": "node -e \"console.log('axe harness scaffolded; hard assertions enable in Task 4')\""
  },
  "dependencies": {
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "framer-motion": "^11.3.0",
    "geist": "^1.3.1",
    "lucide-react": "^0.453.0",
    "next": "14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.15",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3"
  }
}
