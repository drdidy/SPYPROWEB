# Vercel Python function env-vars for the SPX Channel engine.
#
# Set these in Vercel: Project Settings -> Environment Variables.
# api/spx/snapshot.py reads them at request time. Never commit values.

# ---------------------------------------------------------------------------
# Tastytrade — OAuth2 with refresh token (production)
# https://developer.tastytrade.com/
#
# Register a Tastytrade OAuth application once to get the client_id +
# client_secret. Complete the authorization-code flow once to obtain
# the long-lived refresh_token. The function exchanges
# refresh_token -> access_token at request time and caches the
# access_token between requests.
#
# Currently a stub (api/_lib/spx_data/tastytrade_backend.py); the
# engine falls back to yfinance until the OAuth exchange is wired.
# ---------------------------------------------------------------------------
TASTYTRADE_CLIENT_ID=
TASTYTRADE_CLIENT_SECRET=
TASTYTRADE_REFRESH_TOKEN=

# ---------------------------------------------------------------------------
# Unusual Whales — options flow / GEX / dark pools
# https://unusualwhales.com/api
# Reserved for confluence factors 4 + 5 once specified.
# ---------------------------------------------------------------------------
UNUSUAL_WHALES_API_KEY=

# ---------------------------------------------------------------------------
# OpenAI — daily-brief generation
# https://platform.openai.com/api-keys
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Tunables
# ---------------------------------------------------------------------------
# In-process cache for /api/spx/snapshot (seconds).
SPX_SNAPSHOT_TTL=30
